{
  "version": 2,
  "cleanUrls": false,
  "crons": [
    {
      "path": "/api/ping",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/pages/login.html"
    },
    {
      "source": "/home",
      "destination": "/pages/home.html"
    },
    {
      "source": "/pages/home.html",
      "destination": "/pages/home.html"
    },
    {
      "source": "/pages/login.html",
      "destination": "/pages/login.html"
    }
  ]
}
