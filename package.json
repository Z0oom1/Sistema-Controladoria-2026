{
  "name": "sistema-wilson",
  "version": "3.6.9",
  "description": "Sistema de Controle",
  "main": "frontend/main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server/server.js",
    "dev": "concurrently -k \"node server/server.js\" \"vite\" \"electron .\"",
    "build": "vite build && electron-builder",
    "build:vercel": "vite build && cp -r frontend/js dist/"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0"
  },
  "build": {
    "appId": "com.wilson.controladoria",
    "productName": "Controladoria AW",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "frontend/Imgs/logo.png"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "frontend/Imgs/logo-512.png"
    },
    "dmg": {
      "icon": "frontend/Imgs/logo-512.png"
    },
    "files": [
      "package.json",
      "frontend/**/*"
    ]
  },
  "author": "Caio Rod",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "latest",
    "electron-builder": "^24.13.3",
    "vite": "^7.3.1"
  }
}
